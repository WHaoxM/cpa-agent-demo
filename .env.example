# ═══ 环境变量模板 ═══
# 复制此文件为 .env.local 后填入实际值

# 应用标题（显示在浏览器标签页）
VITE_APP_TITLE=职导星图

# API 模式：
# - 本地开发默认见 .env.development（http）
# - GitHub Pages / 无后端：mock
# - 覆盖：复制本文件为 .env.local
VITE_API_MODE=http

# 后端 origin（仅 http 模式）
# - 留空：走同源 /api + Vite proxy（推荐，不绑死端口）
# - 或填完整 URL：http://127.0.0.1:5001 / http://host:任意端口
VITE_API_BASE_URL=

# Vite 开发代理目标（VITE_API_BASE_URL 为空时生效；改端口只改这里）
VITE_API_PROXY_TARGET=http://127.0.0.1:5001
